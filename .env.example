# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
BROADCAST_CHAT_ID=your_broadcast_channel_id_here

# Database Configuration (auto-provided by Replit)
# DATABASE_URL will be set automatically by Replit PostgreSQL
# Or manually configure:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password
# DB_NAME=crypto_signals

# Trading Configuration
TIMEZONE=UTC
SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT
EXCHANGE=binance
TIMEFRAME=15m

# EMA Strategy Parameters
EMA_FAST=9
EMA_SLOW=21
EMA_TREND=50
TRAIL_PCT=1.5

# Subscription Configuration
SUB_PRICE_USDC=50.0

# Whop Integration (optional)
WHOP_CHECKOUT_URL=https://whop.com/checkout/your-product-id
WHOP_WEBHOOK_SECRET=your_whop_webhook_secret

# Solana Pay Integration (optional)
SOL_MERCHANT=your_solana_wallet_address
SPL_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
HELIUS_WEBHOOK_SECRET=your_helius_webhook_secret

# Server Configuration
PORT=5000

# ── Strategy executor tuning (optional — sensible defaults are baked in) ───────
# You do NOT need to set these unless you want to tune performance on Railway.
# EXECUTOR_SCAN_INTERVAL=10          # crypto scan cycle (seconds)
# EXECUTOR_FOREX_SCAN_INTERVAL=5   # forex/index scan cycle (seconds)
# EXECUTOR_MONITOR_INTERVAL=10     # paper position tracker (seconds)
# EXECUTOR_LIVE_MONITOR_INTERVAL=8 # live position tracker (seconds)
# EXECUTOR_TRADE_MONITOR_INTERVAL=15  # legacy trades table monitor (seconds)
# EXECUTOR_MAX_CONCURRENT=3        # parallel crypto strategy evals
# EXECUTOR_FOREX_MAX_CONCURRENT=6  # parallel forex/index strategy evals
# FMP_POLL_INTERVAL_SECONDS=8    # tradfi price poll when cTrader inactive
# FOREX_SCANNER_PARALLEL=6         # live scanner pair×TF parallelism

# ── Real-time tradfi prices (forex / indices / metals) ───────────────────────
# FMP_API_KEY=your_fmp_key          # 8s REST poll — used when cTrader not linked
# CTRADER_CLIENT_ID=                # Spotware Open API app — required for Connect + live ticks
# CTRADER_CLIENT_SECRET=
# CTRADER_REDIRECT_URI=https://calsbot-production.up.railway.app/api/ctrader/callback
# Must EXACTLY match a redirect URI in Spotware Open API portal (and request host).
# PUBLIC_DOMAIN=tradehubmarkets.com # Used for OAuth callback if REDIRECT_URI unset
# CANONICAL_HOST=www.tradehubmarkets.com # Optional: 301 redirect apex → www (both on Railway)

# Telegram — Railway ONLY (set DISABLE_TELEGRAM_POLL=1 on Replit/dev)
# TELEGRAM_BOT_TOKEN=         # required for trade TP/SL DMs + bot commands
# OWNER_TELEGRAM_ID=          # REQUIRED on Railway — your numeric Telegram user id (hourly health + trade DMs)
# Do NOT set FOREX_BOT_TOKEN to the same value as TELEGRAM_BOT_TOKEN (double poller → conflict)
# DISABLE_TELEGRAM_POLL=1     # use on Replit/local so Railway is the sole poller
