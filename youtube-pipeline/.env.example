# Server
PORT=3000
AUTH_TOKEN=replace-with-a-long-random-secret
TMP_DIR=/tmp
PUBLIC_BASE_URL=https://your-service.up.railway.app

# Database (Neon Postgres — same as calsbot)
NEON_DATABASE_URL=
# DATABASE_URL=

# Encryption for channel OAuth secrets at rest (64-char hex or any passphrase)
ENCRYPTION_KEY=

# Shared platform API keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
CREATOMATE_API_KEY=
CREATOMATE_POLL_INTERVAL_MS=5000
CREATOMATE_POLL_TIMEOUT_MS=900000

# Default upload privacy for new videos (review before publish)
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CATEGORY_ID=28

# Retry policy
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000

# --- Legacy single-channel vars (used only by npm run migrate-channel) ---
DEFAULT_TOPIC=Deep-Dive Cosmic Mysteries
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
ELEVENLABS_VOICE_ID=
CREATOMATE_TEMPLATE_ID=
MIGRATION_CHANNEL_NAME=Default Channel
MIGRATION_UPLOAD_FREQUENCY=0 14 * * *
MIGRATION_MONTHLY_BUDGET_USD=100
