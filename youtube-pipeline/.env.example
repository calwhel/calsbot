# Server
PORT=3000
AUTH_TOKEN=replace-with-a-long-random-secret
TMP_DIR=/tmp
DEFAULT_TOPIC=Deep-Dive Cosmic Mysteries
# Public URL Creatomate uses to fetch ephemeral audio (auto-set on Railway via RAILWAY_PUBLIC_DOMAIN)
PUBLIC_BASE_URL=https://your-service.up.railway.app

# Anthropic (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Creatomate video rendering
CREATOMATE_API_KEY=
CREATOMATE_TEMPLATE_ID=
CREATOMATE_POLL_INTERVAL_MS=5000
CREATOMATE_POLL_TIMEOUT_MS=900000

# YouTube Data API v3 (OAuth2 refresh token flow)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CATEGORY_ID=28

# Retry policy
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000
