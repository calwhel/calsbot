modules = ["python-3.11", "nodejs-20", "python3", "postgresql-16"]
[agent]
expertMode = true
integrations = ["python_openai_ai_integrations:1.0.0", "python_gemini_ai_integrations:1.0.0", "python_anthropic_ai_integrations:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cairo", "cargo", "ffmpeg-full", "fontconfig", "freetype", "ghostscript", "glib", "glibcLocales", "gobject-introspection", "gtk3", "harfbuzz", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "openssl", "pango", "pkg-config", "qhull", "rustc", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Trade Tracker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Strategy Portal"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mobile App"

[[workflows.workflow]]
name = "Trade Tracker"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 tracker_server.py"
waitForPort = 8000

[[workflows.workflow]]
name = "Strategy Portal"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "while true; do echo '[portal] starting...'; gunicorn -w 2 -k uvicorn.workers.UvicornWorker --max-requests 300 --max-requests-jitter 30 --bind 0.0.0.0:5000 --timeout 300 --graceful-timeout 60 --log-level info strategy_portal_server:app; echo '[portal] exited — restarting in 5s...'; sleep 5; done"
waitForPort = 5000

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m uvicorn main:app --host 0.0.0.0 --port 8080"

[[workflows.workflow]]
name = "Mobile App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mobile && while true; do echo '[mobile] starting expo tunnel...'; CI=1 EXPO_PUBLIC_API_URL=https://tradehubmarkets.com npx expo start --port 8081 --tunnel; echo '[mobile] expo exited (likely ngrok hiccup) — retrying in 5s...'; sleep 5; done"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["bash", "scripts/start_production.sh"]

[userenv]

[userenv.shared]
GOOGLE_CLIENT_ID = "378619424193-s9926m8c43onme0t5egidbhkfc7ukuur.apps.googleusercontent.com"

[userenv.production]
FORCE_EXECUTOR = "1"

[userenv.development]
DISABLE_EXECUTOR = "1"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
